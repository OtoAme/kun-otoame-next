model patch_resource {
  id       Int      @id @default(autoincrement())
  section  String   @db.VarChar(107)
  name     String   @default("") @db.VarChar(300)
  note     String   @default("") @db.VarChar(10007)
  type     String[]
  language String[]
  platform String[]
  download Int      @default(0)
  // 0 - normal, 1 - banned, 2 - pending approval
  status   Int      @default(0)

  like_by user_patch_resource_like_relation[]
  links   patch_resource_link[]
  access  patch_resource_access[]
  grants  patch_resource_access_grant[] @relation("patch_resource_access_grant")

  user_id  Int
  user     user  @relation("user_patch_resource", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  patch_id Int
  patch    patch @relation("patch_resource", fields: [patch_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  created DateTime @default(now())
  updated DateTime @updatedAt

  @@index([patch_id])
  @@index([patch_id, status])
  @@index([user_id, status])
  @@index([section, status, created(sort: Desc)])
}

model patch_resource_link {
  id         Int    @id @default(autoincrement())
  storage    String @db.VarChar(107)
  size       String @default("") @db.VarChar(107)
  code       String @default("") @db.VarChar(1007)
  password   String @default("") @db.VarChar(1007)
  hash       String @default("")
  content    String @default("")
  sort_order Int    @default(0)
  download   Int    @default(0)

  resource_id Int
  resource    patch_resource @relation(fields: [resource_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  access      patch_resource_access[]

  created DateTime @default(now())
  updated DateTime @updatedAt

  @@index([resource_id, sort_order])
}

model patch_resource_access_grant {
  actor_key String   @db.VarChar(80)
  expires   DateTime

  resource_id Int
  resource    patch_resource @relation("patch_resource_access_grant", fields: [resource_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([actor_key, resource_id])
  @@index([expires], map: "resource_access_grant_expires_idx")
}

model patch_resource_access {
  id            Int      @id @default(autoincrement())
  actor_type    String   @db.VarChar(20)
  visitor_token String   @default("") @db.VarChar(64)
  access_kind   String   @default("link_reveal") @db.VarChar(20)
  section       String   @db.VarChar(107)
  storage       String   @db.VarChar(107)
  cost          Int      @default(0)
  expires       DateTime

  user_id Int?
  user    user? @relation("user_patch_resource_access", fields: [user_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  patch_id Int
  patch    patch @relation("patch_resource_access", fields: [patch_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  resource_id Int
  resource    patch_resource @relation(fields: [resource_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  link_id Int
  link    patch_resource_link @relation(fields: [link_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  created DateTime @default(now())
  updated DateTime @updatedAt

  @@index([user_id, link_id, expires])
  @@index([visitor_token, link_id, expires])
  @@index([patch_id, created(sort: Desc)])
  @@index([resource_id, created(sort: Desc)])
  @@index([link_id, created(sort: Desc)])
  @@index([actor_type, visitor_token, section, access_kind, created(sort: Desc)], map: "resource_access_visitor_kind_created_idx")
}

model user_patch_resource_like_relation {
  id Int @id @default(autoincrement())

  user_id     Int
  user        user           @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  resource_id Int
  resource    patch_resource @relation(fields: [resource_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  created DateTime @default(now())
  updated DateTime @updatedAt

  @@unique([user_id, resource_id])
  @@index([resource_id])
}
